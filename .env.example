# ======================================================================
# Tapstar — environment configuration
#
# Copy this file to `.env` for local dev, or render it into
# /etc/tapstar/tapstar.env on the production server.
# See DEPLOYMENT.md for the full deployment flow.
# ======================================================================

# ---- Django core ----
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-this-to-a-random-long-string

# Leave True for local dev, False in production.
DEBUG=True

# Comma-separated. Include the public domain + any private hosts.
# Production example: tapstart.1techspace.in,www.tapstart.1techspace.in
ALLOWED_HOSTS=localhost,127.0.0.1

# Full URL (scheme://host) of any origin that POSTs to Django.
# Production example: https://tapstart.1techspace.in
CSRF_TRUSTED_ORIGINS=

# Full public URL of the site — used for absolute links in emails etc.
# Production example: https://tapstart.1techspace.in
SITE_URL=http://localhost:8000


# ---- Database ----
# SQLite is the default when blank (good for dev). For production use
# Postgres:
#   DATABASE_URL=postgres://tapstar:STRONGPASSWORD@127.0.0.1:5432/tapstar
DATABASE_URL=


# ---- Media / static ----
# Optional absolute path for uploaded media. Defaults to <project>/media.
# Production example: /var/www/tapstar/media
# MEDIA_ROOT=


# ---- HTTPS / security (only enable in production behind nginx+TLS) ----
# After certbot issues a cert and nginx is redirecting HTTP→HTTPS, flip
# these to True. Start with HSTS small (e.g. 3600) while verifying, then
# raise to 31536000 and enable preload.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False


# ---- Logging ----
# DEBUG in dev, INFO or WARNING in prod.
LOG_LEVEL=DEBUG
# Optional — writes a rotating file in addition to stdout.
# Production example: /var/log/tapstar
# LOG_DIR=


# ---- Redis / Celery ----
REDIS_URL=redis://localhost:6379/0
# True runs tasks inline (no worker). Flip to False in prod once a
# celery worker is running as its own systemd unit.
CELERY_TASK_ALWAYS_EAGER=True


# ---- Anthropic (Claude) ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514


# ---- Google Places (optional) ----
# Enables primary photo fallback on the customer review page when a
# business has a Place ID but no uploaded logo. Without this key the
# page falls back to a branded gradient initial.
GOOGLE_PLACES_API_KEY=


# ---- Easebuzz (Indian payment gateway — UPI + cards + net banking) ----
EASEBUZZ_KEY=
EASEBUZZ_SALT=
# "test" for sandbox, "prod" for live payouts.
EASEBUZZ_ENV=test


# ---- Email ----
# Console backend prints mails to stdout — fine for dev, swap to SMTP
# (or SendGrid/Mailgun/SES) in prod.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Tapstar <noreply@tapstar.in>
